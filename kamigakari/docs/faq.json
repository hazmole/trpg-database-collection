    "entries": [
      {
        "type": "section",
        "title": "世界觀章節",
        "entries": [
          {
            "type": "custom",
            "parser": "faq",
            "datas": [
              {
                "title": "基本－W－001",
                "reference": "p.016 「斷片」",
                "Q": "寄宿在神我狩靈魂中的斷片，是否能透過外科手術等物理手段來去除？",
                "A": "不行。由於斷片是寄宿在靈魂之中，因此無法透過物理手段去除。"
              },
              {
                "title": "基本－W－002",
                "reference": "p.024 「靈紋」",
                "Q": "〈人造神器〉中是否存在［靈紋］？",
                "A": "存在。但是其無法被用於［靈紋燃燒］等功能。"
              },
              {
                "title": "基本－W－003",
                "reference": "p.024 「靈肉」",
                "Q": "假設遭遇被變成「靈肉」的受害者。是否能僅憑靈肉來特定受害者的身分，或是掌握其容貌？",
                "A": "不行。靈肉無法用來辨識個人身分，也無法從中獲得指紋或 DNA 等情報。因此，基本上只能透過周遭遺留的物品來推測受害者的身分。"
              },
              {
                "title": "基本－W－004",
                "reference": "p.035 「久代市」",
                "Q": "請問與久代市相鄰的海叫什麼名字？",
                "A": "是太平洋。詳情請參閱基本規則書的「久代市概要」章節。"
              }
            ]
          }
        ]
      },
      {
        "type": "section",
        "title": "玩家章節",
        "entries": [
          {
            "type": "custom",
            "parser": "faq",
            "datas": [
              {
                "title": "基本－P－001",
                "reference": "p.062~　原創 PC 的創建",
                "Q": "世界干涉等級 2 以上的新創 PC，也能獲得團務開始時的額外「+200 G」嗎？",
                "A": "是的，可以獲得。"
              },
              {
                "title": "基本－P－002",
                "reference": "p.062~　原創 PC 的創建",
                "Q": "在創建角色時，可以在左邊寫有數字的《天賦》欄位上取得並填入《種族天賦》嗎？",
                "A": "是的，可以這麼做。"
              },
              {
                "title": "基本－P－003",
                "reference": "p.064~　天賦的欄位說明",
                "Q": "有些［時機：常駐］的《天賦》會在［傷害減少時］或［傷害計算時］等情況下發揮效果。如果說在例如［傷害減少時］同時使用多個同名的《天賦》，它們的效果會重複發揮作用嗎？",
                "A": "不會。這個情況下會適用「除非效果特別記述，否則相同名稱的《天賦》不會對同一個［對象］重複、累積發揮效果」的規則（參照基本規則書 p.64~65），因此效果不會重複適用。"
              },
              {
                "title": "基本－P－004",
                "reference": "p.064~　天賦的欄位說明",
                "Q": "［代價：ｎ、ｎ］是否也包括了［代價：連號］和「代價：對數」？",
                "A": "是的，包括在內。"
              },
              {
                "title": "基本－P－005",
                "reference": "p.064~　天賦的欄位說明",
                "Q": "［代價：ｎ］是否也包括了［代價：奇］和［代價：偶］？",
                "A": "是的，包括在內。"
              },
              {
                "title": "基本－P－006",
                "reference": "p.064~　天賦的欄位說明",
                "Q": "在［戰鬥外］可以使用《天賦》嗎？",
                "A": [
                  "可以，但會受到以下限制：",
                  {
                    "type": "list",
                    "entries": [
                      "在［戰鬥外］消耗的［靈力］，必須等到該場景結束、或是 GM 宣告［戰鬥開始］為止，才能擲骰恢復。",
                      "除了［時機：常駐］以外的《天賦》，在同一個場景中最多各只能使用 1 次。"
                    ]
                  }
                ]
